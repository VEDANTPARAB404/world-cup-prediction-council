# OPENAI_API_KEY: Optional API key to connect OpenAI as the primary AI engine for simulations and live updates.
# Configure this via the Settings menu or platform secrets.
OPENAI_API_KEY=""

# OPENAI_MODEL: Optional OpenAI model slug (e.g., gpt-4o-mini, gpt-4o).
# Default is gpt-4o-mini if not specified.
OPENAI_MODEL="gpt-4o-mini"

# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=""

# GROQ_API_KEY: Optional API key to connect Groq instead of Gemini for simulations.
# Configure this via the Settings menu or platform secrets if you wish to run simulations on Groq.
GROQ_API_KEY=""

# GROQ_MODEL: Optional Groq model slug (e.g., llama-3.3-70b-versatile, llama-3.1-8b-instant).
# Default is llama-3.3-70b-versatile if not specified.
GROQ_MODEL="llama-3.3-70b-versatile"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# FOOTBALL_DATA_API_KEY: Optional API key for Football-Data.org
FOOTBALL_DATA_API_KEY=""

# API_FOOTBALL_KEY: Optional API key for API-Football (RapidAPI)
API_FOOTBALL_KEY=""
